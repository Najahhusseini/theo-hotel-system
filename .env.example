# THEO Environment Configuration
# Copy this file to .env and update values

# Environment
ENVIRONMENT=development
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://theo_admin:theo_password@postgres:5432/theo_database
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true
SQL_ECHO=false

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-min-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# PostgreSQL (for docker-compose)
POSTGRES_USER=theo_admin
POSTGRES_PASSWORD=theo_password
POSTGRES_DB=theo_database